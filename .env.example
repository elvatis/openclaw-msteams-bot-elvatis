# MS Teams Bot Credentials (Azure Bot Registration)
TEAMS_APP_ID=your-azure-app-id
TEAMS_APP_PASSWORD=your-azure-app-password
TEAMS_APP_TENANT_ID=your-tenant-id

# Bot HTTP port (default: 3978)
TEAMS_PORT=3978

# Channel-to-model mapping (JSON)
# Each key is an exact Teams channel name, value is the config for that channel.
# model must be a valid OpenClaw model identifier.
# Example:
TEAMS_CHANNELS={General:{model:vllm/cli-claude/claude-sonnet-4-6,systemPrompt:You are a helpful assistant.}}

# Path to the OpenClaw binary (default: /usr/bin/openclaw)
OPENCLAW_BIN=/usr/bin/openclaw

# OpenClaw Gateway connection (only needed for WebSocket mode)
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
